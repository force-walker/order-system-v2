{
  "name": "order-system-v2-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "preview": "vite preview",
    "gen:types": "openapi-typescript ../docs/openapi-mvp-skeleton-draft.yaml -o src/generated/openapi.ts",
    "gen:types:check": "openapi-typescript ../docs/openapi-mvp-skeleton-draft.yaml -o src/generated/openapi.ts --check"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  }
}
